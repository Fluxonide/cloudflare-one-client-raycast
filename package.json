{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "cloudflare-one-client",
  "title": "Cloudflare One Client",
  "description": "Manage Cloudflare One (WARP) client — connect, disconnect, and change modes",
  "icon": "icon.png",
  "author": "ranit",
  "categories": ["Productivity", "Developer Tools"],
  "license": "MIT",
  "platforms": ["Windows"],
  "commands": [
    {
      "name": "warp-status",
      "title": "Cloudflare One Client",
      "description": "Manage Cloudflare WARP — connect, disconnect, change mode",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.103.0",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
